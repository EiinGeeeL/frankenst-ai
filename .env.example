# When secrets are in Azure Key Vault and accessible via DefaultAzureCredential (optional)
AZURE_KEY_VAULT_NAME=

# LLM Foundry Inference Configuration (optional, only if using Azure for inference)
AZURE_INFERENCE_ENDPOINT=
AZURE_INFERENCE_CREDENTIAL=
AZURE_INFERENCE_MODEL_NAME=
AZURE_INFERENCE_API_VERSION=

# LLM Foundry Embeddings Configuration (optional, only if using Azure for embeddings)
AZURE_EMBEDDINGS_ENDPOINT=
AZURE_EMBEDDINGS_CREDENTIAL=
AZURE_EMBEDDINGS_MODEL_NAME=
AZURE_EMBEDDINGS_API_VERSION=

# Azure Application Insights (optional, for tracing and monitoring)
AZURE_APP_INSIGHT_CONNECTION_STRING=
PROJECT_CONNECTION_STRING=
PROJECT_KEY=

# Azure Search Configuration (optional, only if using Azure Search for retrieval)
AZURE_SEARCH_SERVICE_ENDPOINT=
AZURE_SEARCH_API_KEY=

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_FILE=false